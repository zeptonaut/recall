{
  "name": "recall",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 4321",
    "build": "next build",
    "start": "next start --port 4321",
    "lint": "eslint",
    "test": "node scripts/run-with-node-env.mjs test tsx --test src/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "yarn db:migrate:dev && yarn db:migrate:test",
    "db:migrate:dev": "drizzle-kit migrate",
    "db:migrate:test": "node scripts/run-with-node-env.mjs test drizzle-kit migrate",
    "db:reset": "yarn db:reset:dev && yarn db:reset:test",
    "db:reset:dev": "tsx src/db/reset.ts && yarn db:migrate:dev",
    "db:reset:test": "node scripts/run-with-node-env.mjs test tsx src/db/reset.ts && yarn db:migrate:test",
    "db:studio": "drizzle-kit studio",
    "db:studio:test": "node scripts/run-with-node-env.mjs test drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:test": "node scripts/run-with-node-env.mjs test tsx src/db/seed.ts"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "ts-fsrs": "^5.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
